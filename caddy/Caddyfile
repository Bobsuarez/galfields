# ═══════════════════════════════════════════════════════════════════════════
# KindredWorks — Producción
# TLS gestionado automáticamente (Let's Encrypt / ZeroSSL)
# ═══════════════════════════════════════════════════════════════════════════

# ── Snippets reutilizables ─────────────────────────────────────────────────

{
    order coraza_waf first
}

# IPs maliciosas conocidas — agregar más según logs de acceso
(bloquear_ips) {
    @ips_bloqueadas remote_ip 65.2.69.132
    handle @ips_bloqueadas {
        respond "Forbidden" 403
    }
}

# Rutas de exploits y scanners — cerrar conexión sin respuesta (equiv. nginx 444)
(bloquear_scanners) {
    @scanners path_regexp /(wp-admin|wp-login|wp-config|xmlrpc\.php|\.env|\.git|cgi-bin|bin/sh|bin/bash|\.php$)
    handle @scanners {
        abort
    }
    @traversal path_regexp (\.\./|%2e%2e|%252e|\.\.%2f)
    handle @traversal {
        abort
    }
}

# ── Rate Limiting ──────────────────────────────────────────────────────────
# Login: 5 intentos/minuto por IP (fuerza bruta)
(rate_limit_login) {
    rate_limit {
        zone login_zone {
            key {remote_host}
            events 5
            window 1m
        }
    }
}

# API general: 300 requests/minuto por IP (uso normal del frontend)
(rate_limit_api) {
    rate_limit {
        zone api_zone {
            key {remote_host}
            events 500
            window 1m
            burst 500
        }
    }
}

# Tracking de clics en email: 200 requests/10 minutos por IP
(rate_limit_tracking) {
    rate_limit {
        zone tracking_zone {
            key {remote_host}
            events 200
            window 10m
        }
    }
}

# ── WAF con Coraza (DEFENSA ACTIVA) ─────────────────────────────────────────
(waf) {
    coraza_waf {
        directives `
            Include /etc/caddy/coraza.conf
            Include /etc/caddy/crs-setup.conf
            Include /etc/caddy/owasp_crs/rules/*.conf
            SecRuleEngine On
            SecDebugLog /dev/null
            SecDebugLogLevel 0
            SecRuleRemoveById 920430 920600 922100
        `
    }
}

# Headers de seguridad
(headers_seguridad) {
    header {
        -Server
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        X-XSS-Protection          "1; mode=block"
        Referrer-Policy           "no-referrer"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
        Pragma "no-cache" # Compatibilidad con navegadores antiguos
        Expires "0"
        Content-Security-Policy "
                   default-src 'self';
                   script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net;
                   style-src 'self' 'unsafe-inline';
                   img-src 'self' data: https:;
                   font-src 'self';
                   connect-src 'self' https://api.kinforgeworks.com;
                   frame-ancestors 'none';
                   form-action 'self';
                   base-uri 'self';
               "
        # HSTS (forzar HTTPS por 1 año)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }
}

# ── Capturar cualquier dominio no reconocido ───────────────────────────────
:443 {
    tls internal
    respond "Not Found" 404
}

# ── European Masters — Frontend + Backend API ──────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════
# SITIO PRINCIPAL
# ═══════════════════════════════════════════════════════════════════════════
kinforgeworks.com, www.kinforgeworks.com {

    # 1. Bloqueos básicos
    import bloquear_ips
    import bloquear_scanners

    # 2. Cabeceras de seguridad
    import headers_seguridad

    # 3. WAF (filtra SQLi, XSS, etc.)
    import waf

    # 4. Logs estructurados (para Fail2ban o monitoreo)
    log {
        output file /var/log/caddy/kinforgeworks-access.log {
            roll_size 100mb
            roll_keep 10
        }
        format json
    }

    # 2. API
    handle /api/v1/t/* {
        import rate_limit_tracking
        reverse_proxy em-leads:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            transport http {
                versions 1.1 2
                keepalive 30s
                keepalive_idle_conns 10
            }
        }
    }

    handle /api/v1/auth/* {
        import rate_limit_login
        reverse_proxy em-leads:8080 {
            # Esto es vital para que el backend no se confunda
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            transport http {
                versions 1.1 2
                keepalive 30s
                keepalive_idle_conns 10
            }
        }
    }

    handle /api/v1/* {
        import rate_limit_api
        reverse_proxy em-leads:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            transport http {
                versions 1.1 2
                keepalive 30s
                keepalive_idle_conns 10
            }
        }
    }

    # 6. Frontend Astro (todo lo demás)
    handle {
        reverse_proxy em-web:80
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# BONUS: Redirigir HTTP a HTTPS (para producción)
# ═══════════════════════════════════════════════════════════════════════════
kinforgeworks.com:80, www.kinforgeworks.com:80 {
    redir https://{host}{uri} permanent
}

# ── CDN para archivos de maestrías (MinIO) ────────────────────────────────
cdn.kinforgeworks.com {
    import bloquear_ips

    header {
        Cache-Control "public, max-age=31536000, immutable"
        X-Content-Type-Options "nosniff"
    }

    encode gzip zstd

    handle /programs/* {
        rewrite * /programs-assets{uri}
        reverse_proxy minio:9000 {
            header_up Host {upstream_hostport}
        }
    }

    handle /files/* {
        rewrite * /programs-assets{uri}
        reverse_proxy minio:9000 {
            header_up Host {upstream_hostport}
        }
    }

    respond "Not Found" 404
}

# ── n8n — Panel de automatización (acceso restringido por IP) ─────────────
# IMPORTANTE: cambiar 127.0.0.1 por tu IP estática o rango CIDR (ej: 203.0.113.5)
n8n.kinforgeworks.com {
    import bloquear_ips
    import headers_seguridad

    @autorizado remote_ip 127.0.0.1
    handle @autorizado {
        reverse_proxy n8n:5678 {
            header_up Host              {upstream_hostport}
            header_up X-Real-IP         {remote_host}
        }
    }
    respond "403 Forbidden" 403

    log {
        output file /var/log/caddy/kinforgeworks-access.log {
            roll_size 100mb
            roll_keep 10
        }
        format json
    }
}
