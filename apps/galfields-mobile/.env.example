# Obtén tu key gratuita en https://clipdrop.co/apis
EXPO_PUBLIC_CLIPDROP_API_KEY=your_clipdrop_api_key_here

# URL base del backend pos (Spring Boot). En dispositivo físico con Expo Go
# "localhost" no resuelve a tu máquina de desarrollo — usa la IP LAN, ej. http://192.168.1.50:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
