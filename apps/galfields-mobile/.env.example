# URL base del backend pos (Spring Boot). En dispositivo físico con Expo Go
# "localhost" no resuelve a tu máquina de desarrollo — usa la IP LAN, ej. http://192.168.1.50:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# API key de la Custom Search JSON API de Google (Google Cloud Console),
# usada por la búsqueda de imágenes de producto — ver services/image-search.ts.
# El buscador (cx) en sí está hardcodeado ahí, no es secreto.
EXPO_PUBLIC_GOOGLE_CSE_API_KEY=your_google_cse_api_key_here

# Alternativa a lo anterior para la misma búsqueda de imágenes, vía
# serpapi.com (engine=google_images) — solo se usa si en Configuración →
# Búsqueda de imágenes eliges "SerpApi" en vez de "Google Custom Search".
EXPO_PUBLIC_SERPAPI_API_KEY=your_serpapi_api_key_here
